---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AudioCard from '../../components/AudioCard.astro';
import SearchBar from '../../components/SearchBar.astro';
import audioData from '../../data/audio.json';

const { series, items: standaloneItems } = audioData;

function totalHours(items: { durationSeconds: number }[]): number {
  return Math.round(items.reduce((sum, i) => sum + (i.durationSeconds || 0), 0) / 3600);
}
---

<BaseLayout
  title="الصوتيات"
  titleTi="ዝስማዕ"
  description="دروس ومحاضرات إسلامية صوتية باللغة التجرينية"
>
  <!-- Page Header -->
  <section class="hero-gradient text-white py-16">
    <div class="container text-center">
      <div class="trilingual-title items-center mb-6">
        <h1 class="ar text-4xl font-bold text-white">الصوتيات الإسلامية</h1>
        <p class="en text-xl text-accent font-medium">Islamic Audio</p>
        <p class="ti text-lg text-white/80 font-ethiopic">እስላማዊ ዝስማዕ</p>
      </div>
      <p class="text-lg opacity-90 max-w-2xl mx-auto mb-4">
        دروس ومحاضرات صوتية من علمائنا
      </p>
      <p class="text-base opacity-75 max-w-2xl mx-auto mb-8">
        Audio lessons and lectures from our scholars
      </p>
      <div class="flex justify-center">
        <SearchBar placeholder="ابحث في الصوتيات..." />
      </div>
    </div>
  </section>

  <!-- Series -->
  <section class="py-12 bg-cream">
    <div class="container">
      <div class="trilingual-title mb-8">
        <h2 class="ar text-2xl font-bold text-text-dark font-amiri">السلاسل الصوتية</h2>
        <p class="ti text-sm text-text-light font-ethiopic">ተኸታታሊ ትምህርትታት</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {series.map((s) => (
          <a href={`/audio/${s.slug}`} class="card p-6 group block">
            <div class="flex items-start gap-5">
              <div class="w-20 h-20 rounded-xl bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform">
                <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              </div>

              <div class="flex-1 min-w-0">
                <div class="bilingual-title mb-2">
                  <h3 class="ar text-xl font-bold text-text-dark font-amiri group-hover:text-primary transition-colors">
                    {s.titleAr}
                  </h3>
                  <p class="ti text-sm text-text-light font-ethiopic">{s.titleTi}</p>
                </div>

                <p class="text-sm text-text-light flex items-center gap-1 mb-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <span>{s.scholarAr}</span>
                  <span class="font-ethiopic text-xs opacity-80">({s.scholarTi})</span>
                </p>
                <p class="text-xs text-text-light font-ethiopic mb-3">{s.descriptionTi}</p>

                <div class="flex flex-wrap items-center gap-2">
                  <span class="badge bg-primary text-white text-xs">{s.items.length} درس</span>
                  {s.groups.length > 0 && (
                    <span class="badge bg-accent text-white text-xs">{s.groups.length} سورة</span>
                  )}
                  <span class="text-xs text-text-light flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span dir="ltr">~{totalHours(s.items)}</span> ساعة
                  </span>
                </div>
              </div>

              <svg class="w-6 h-6 text-text-light group-hover:text-primary transition-colors rotate-180 self-center flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Standalone audio (lectures, khutbas, …) -->
  {standaloneItems.length > 0 && (
    <section class="py-12 bg-white">
      <div class="container">
        <div class="trilingual-title mb-8">
          <h2 class="ar text-2xl font-bold text-text-dark font-amiri">تسجيلات متنوعة</h2>
          <p class="ti text-sm text-text-light font-ethiopic">ዝተፈላለዩ ቅዳሓት</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {standaloneItems.map((audio) => (
            <AudioCard {...audio} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .font-amiri {
    font-family: var(--font-amiri);
  }
  .font-ethiopic {
    font-family: var(--font-ethiopic);
  }
</style>
